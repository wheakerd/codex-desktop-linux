path_without_entry() {
    local path_value="$1"
    local entry_to_remove="$2"
    local remaining
    local entry
    local result=""
    local separator=""

    remaining="$path_value:"
    while [ -n "$remaining" ]; do
        entry="${remaining%%:*}"
        remaining="${remaining#*:}"
        if [ "$entry" != "$entry_to_remove" ]; then
            result="$result$separator$entry"
            separator=:
        fi
    done

    printf '%s\n' "$result"
}

